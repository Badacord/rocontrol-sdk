{
  "_note": "Shared request/response contract fixtures for the SDK <-> backend boundary. Consumed by both repos to keep the wire format in sync. Expanded in Phases 2/4.",
  "protocolVersion": "sdk-v1",
  "routes": {
    "registerSchedule": {
      "method": "POST",
      "path": "/api/sdk/v1/schedules",
      "idempotencyKey": "<derivedUniverseId>:schedule:<scheduleHash>:<placeVersion>"
    },
    "reportEvent": {
      "method": "POST",
      "path": "/api/sdk/v1/events",
      "idempotencyKey": "<derivedUniverseId>:event:<occurrenceId>"
    },
    "upcomingEvents": { "method": "GET", "path": "/api/sdk/v1/events/upcoming" },
    "health": { "method": "GET", "path": "/api/sdk/v1/health" }
  },
  "responses": {
    "upcomingEvents": {
      "ok": true,
      "requestId": "req_00000000-0000-0000-0000-000000000000",
